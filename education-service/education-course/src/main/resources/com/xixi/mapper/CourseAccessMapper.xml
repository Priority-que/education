<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xixi.mapper.CourseAccessMapper">

    <select id="selectByCourseId" resultType="com.xixi.entity.CourseAccess">
        SELECT *
        FROM course_access
        WHERE course_id = #{courseId}
        LIMIT 1
    </select>

    <select id="selectByCourseIds" resultType="com.xixi.entity.CourseAccess">
        SELECT *
        FROM course_access
        WHERE course_id IN
        <foreach collection="courseIds" item="courseId" open="(" separator="," close=")">
            #{courseId}
        </foreach>
    </select>

</mapper>
