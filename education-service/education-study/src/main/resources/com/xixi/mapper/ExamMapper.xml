<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xixi.mapper.ExamMapper">

    <!-- 测验结果映射 -->
    <resultMap id="ExamVoMap" type="com.xixi.pojo.vo.ExamVo">
        <id column="id" property="id"/>
        <result column="course_id" property="courseId"/>
        <result column="teacher_id" property="teacherId"/>
        <result column="exam_title" property="examTitle"/>
        <result column="exam_description" property="examDescription"/>
        <result column="exam_type" property="examType"/>
        <result column="total_score" property="totalScore"/>
        <result column="pass_score" property="passScore"/>
        <result column="time_limit" property="timeLimit"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="status" property="status"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <!-- 分页查询课程测验列表 -->
    <select id="selectExamPage" resultMap="ExamVoMap">
        SELECT
            e.id,
            e.course_id,
            e.teacher_id,
            e.exam_title,
            e.exam_description,
            e.exam_type,
            e.total_score,
            e.pass_score,
            e.time_limit,
            e.start_time,
            e.end_time,
            e.status,
            e.created_time
        FROM exam e
        <where>
            <if test="q.courseId != null">
                AND e.course_id = #{q.courseId}
            </if>
            <!-- 学生端显示已发布、进行中和已结束的测验（已结束的用于查看历史记录和成绩） -->
            AND (e.status = 'PUBLISHED' OR e.status = 'IN_PROGRESS' OR e.status = 'ENDED')
        </where>
        ORDER BY e.start_time DESC, e.created_time DESC
    </select>

    <!-- 教师端分页查询测验列表 -->
    <select id="selectTeacherExamPage" resultMap="ExamVoMap">
        SELECT
            e.id,
            e.course_id,
            e.teacher_id,
            e.exam_title,
            e.exam_description,
            e.exam_type,
            e.total_score,
            e.pass_score,
            e.time_limit,
            e.start_time,
            e.end_time,
            e.status,
            e.created_time
        FROM exam e
        <where>
            <if test="q.teacherId != null">
                AND e.teacher_id = #{q.teacherId}
            </if>
            <if test="q.courseId != null">
                AND e.course_id = #{q.courseId}
            </if>
            <if test="q.status != null and q.status != ''">
                AND e.status = #{q.status}
            </if>
            <if test="q.examType != null and q.examType != ''">
                AND e.exam_type = #{q.examType}
            </if>
        </where>
        ORDER BY
        <choose>
            <when test="q.sortBy != null and q.sortBy == 'startTime'">
                e.start_time
            </when>
            <when test="q.sortBy != null and q.sortBy == 'endTime'">
                e.end_time
            </when>
            <otherwise>
                e.created_time
            </otherwise>
        </choose>
        <choose>
            <when test="q.sortOrder != null and q.sortOrder == 'ASC'">
                ASC
            </when>
            <otherwise>
                DESC
            </otherwise>
        </choose>
    </select>

    <!-- 查询测验详情 -->
    <select id="selectExamDetail" resultMap="ExamVoMap">
        SELECT
            e.id,
            e.course_id,
            e.teacher_id,
            e.exam_title,
            e.exam_description,
            e.exam_type,
            e.total_score,
            e.pass_score,
            e.time_limit,
            e.start_time,
            e.end_time,
            e.status,
            e.created_time
        FROM exam e
        WHERE e.id = #{examId}
          AND (e.status = 'PUBLISHED' OR e.status = 'IN_PROGRESS' OR e.status = 'ENDED')
    </select>

    <!-- 教师端根据ID查询测验 -->
    <select id="selectTeacherExamById" resultType="com.xixi.entity.Exam">
        SELECT
            id,
            course_id,
            teacher_id,
            exam_title,
            exam_description,
            exam_type,
            total_score,
            pass_score,
            time_limit,
            start_time,
            end_time,
            status,
            created_time,
            updated_time
        FROM exam
        WHERE id = #{examId}
          AND teacher_id = #{teacherId}
    </select>

    <!-- 教师端删除草稿测验 -->
    <delete id="deleteDraftExam">
        DELETE
        FROM exam
        WHERE id = #{examId}
          AND teacher_id = #{teacherId}
          AND status = 'DRAFT'
    </delete>

</mapper>
